# Spring profile
SPRING_PROFILES_ACTIVE=local

# Database
DB_URL=jdbc:mysql://localhost:3306/church_qt?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=change-me
# Alternative inputs supported by scripts/release_preflight.sh
# DB_HOST=127.0.0.1
# DB_NAME=church_qt
# DB_USER=root

# JWT
APP_JWT_SECRET=change-this-to-a-long-random-secret
APP_ACCESS_TOKEN_EXPIRATION_SECONDS=28800

# Admin console static page exposure (test console only)
APP_ADMIN_CONSOLE_ENABLED=false

# Comma-separated list for split frontend origins
APP_ADMIN_FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
